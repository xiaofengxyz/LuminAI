{
  "name": "jellyfish-frontend",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:film-core": "vite --host 0.0.0.0 --port 24732",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "preview": "vite preview",
    "openapi:fetch": "BACKEND_URL=${VITE_BACKEND_URL:-http://127.0.0.1:24731}; NO_PROXY=localhost,127.0.0.1,::1 curl --noproxy '*' -sSf ${BACKEND_URL}/openapi.json -o ./openapi.json",
    "openapi:gen": "pnpm exec -- openapi --input ./openapi.json --output ./src/services/generated --client fetch --useOptions --useUnionTypes",
    "openapi:update": "pnpm run openapi:fetch && pnpm run openapi:gen"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.10.0",
    "axios": "^1.13.6",
    "i18next": "^23.11.4",
    "i18next-browser-languagedetector": "^7.2.1",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^15.0.1",
    "react-router-dom": "^6.30.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.54.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "msw": "^2.6.6",
    "openapi-typescript-codegen": "^0.30.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
