# .env.example

# 是否使用 Mock 数据（true 时启用 MSW 与本地演示数据）
VITE_USE_MOCK=true

# 后端地址（直连后端时使用）；本地开发默认使用 8011，避免与其他 8000 服务冲突。
# VITE_BACKEND_URL=http://127.0.0.1:8011

# API BaseURL（默认 `${VITE_BACKEND_URL}/api`；如经反向代理部署，可覆盖为 `/api`）
# VITE_API_BASE_URL=http://127.0.0.1:8011/api

# 应用配置示例
# VITE_APP_TITLE=Jellyfish Frontend
