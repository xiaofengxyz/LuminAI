# Jellyfish Backend - 环境变量示例
# 复制为 .env 后按需修改

# 应用
APP_NAME=Jellyfish API
DEBUG=false

# API
API_V1_PREFIX=/api/v1

# 数据库（默认 SQLite 异步）
# DATABASE_URL=sqlite+aiosqlite:///./jellyfish.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/jellyfish
# MySQL 示例（使用 aiomysql 驱动）:
# DATABASE_URL=mysql+aiomysql://user:pass@localhost:3306/jellyfish

# Redis / Celery Broker
# 默认情况下，若未单独指定 CELERY_BROKER_URL，系统会自动使用以下 Redis 配置拼接：
# redis://[:password@]host:port/db
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# 如需单独覆盖，可直接指定完整 broker URL：
# CELERY_BROKER_URL=redis://localhost:6379/0

# CORS 前端地址（逗号分隔）；本地开发默认还会用 CORS_ORIGIN_REGEX 放行 localhost/127.0.0.1 的任意端口。
# CORS_ORIGINS=http://localhost:7788,http://127.0.0.1:7788,http://localhost:7790,http://127.0.0.1:7790
# CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# 图片生成（用于演员/角色/道具/场景/服装/镜头帧图片生成任务）
# IMAGE_API_PROVIDER=openai
# IMAGE_API_BASE_URL=https://example.com/v1/images/generations
# IMAGE_API_KEY=your-image-api-key

# 视频生成（用于 /film/generated_video 等接口）
# VIDEO_API_PROVIDER=openai
# VIDEO_API_BASE_URL=https://example.com/v1/videos/generations
# VIDEO_API_KEY=your-video-api-key

# S3 / 对象存储（素材文件）
# 如使用 AWS S3，可按需填写：
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_REGION_NAME=ap-southeast-1
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=jellyfish-assets
# 可选统一前缀，方便按环境/项目隔离，如 jellyfish/dev
# S3_BASE_PATH=jellyfish/dev
# 若有 CDN/自定义域名，可配置成 https://cdn.example.com
# S3_PUBLIC_BASE_URL=
